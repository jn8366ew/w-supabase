{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "mcp__supabase",
      "Read",
      "Bash",
      "WebFetch",
      "WebSearch",
      "mcp__ide",
      "mcp__shadcn",
      "mcp__playwright",
      "mcp__sequential-thinking",
      "mcp__shadcn",
      "mcp__context7"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["supabase"],
  "language": "korean",
  "outputs": "Explanatory",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --max-warnings=0 \"$CLAUDE_TOOL_OUTPUT_FILE_PATH\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"& { Add-Type -AssemblyName System.Windows.Forms; $n = New-Object System.Windows.Forms.NotifyIcon; $n.Icon = [System.Drawing.SystemIcons]::Information; $n.Visible = $true; $n.ShowBalloonTip(3000, 'Claude Code', 'Task complete', [System.Windows.Forms.ToolTipIcon]::Info); Start-Sleep 3; $n.Dispose() }\""
          }
        ]
      }
    ]
  }
}
