{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "mcp__supabase",
      "Read",
      "Bash",
      "WebFetch",
      "WebSearch",
      "mcp__ide",
      "mcp__shadcn",
      "mcp__playwright",
      "mcp__sequential-thinking",
      "mcp__shadcn",
      "mcp__context7"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["supabase"],
  "language": "korean",
  "outputs": "Explanatory",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint"
          }
        ]
      }
    ]
  }
}
